# Quant Copilot environment variables (DO NOT COMMIT REAL VALUES)
# Copy to .env and fill in. .env is gitignored.

# --- Bitget API credentials (only needed for live trading via BitgetBotRunner).
# Generate demo-trading keys at https://www.bitget.com → API Management.
BITGET_API_KEY=
BITGET_API_SECRET=
BITGET_PASSPHRASE=

# Set to "0" to disable the simulated-trading header (live trading).
BITGET_DEMO=1

# --- Dashboard server (optional; defaults shown).
QUANTCOPILOT_HOST=0.0.0.0
QUANTCOPILOT_PORT=8000

# --- Optional LLM-backed doctor. If unset, the rule-based DiagnoseDoctor is used.
# OPENAI_API_KEY=
# OPENAI_MODEL=gpt-4o-mini

# --- Demo bot (optional; defaults shown).
# DEMO_SYMBOL=BTC